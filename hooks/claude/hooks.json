{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -e '.tool_input.file_path | test(\"\\\\.(env|pem|key)$\")' 2>/dev/null && echo '{\"decision\":\"block\",\"reason\":\"직접 시크릿 파일 수정 금지. 환경변수를 사용하세요.\"}' && exit 2; exit 0"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.content // empty' | wc -l | awk '{if ($1 > 800) {print \"{\\\"decision\\\":\\\"block\\\",\\\"reason\\\":\\\"800줄 초과. 400줄 이하 모듈로 분리하세요.\\\"}\"; exit 2} else {exit 0}}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "POST_WRITE_REVIEW"
          },
          {
            "type": "prompt",
            "prompt": "POST_WRITE_DIAG"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "STOP_REVIEW"
          },
          {
            "type": "prompt",
            "prompt": "STOP_TEST"
          }
        ]
      }
    ]
  }
}
