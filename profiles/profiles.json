{
  "profiles": {
    "cxnexus-backend": {
      "description": "CX Nexus 백엔드 (Java/Spring Boot)",
      "rules": ["common", "cxnexus-backend"],
      "skills": ["common", "cxnexus-backend"],
      "hooks": "kiro-java",
      "testCommand": "./gradlew test"
    },
    "cxnexus-front": {
      "description": "CX Nexus 프론트엔드 (React/TypeScript)",
      "rules": ["common", "cxnexus-front"],
      "skills": ["common"],
      "hooks": "kiro-ts",
      "testCommand": "npm test"
    },
    "axnexus-backend": {
      "description": "AX Nexus 백엔드 (FastAPI/Python)",
      "rules": ["common", "axnexus-backend"],
      "skills": ["common"],
      "hooks": "kiro-python",
      "testCommand": "pytest"
    },
    "axnexus-front": {
      "description": "AX Nexus 프론트엔드 (React/TypeScript)",
      "rules": ["common", "axnexus-front"],
      "skills": ["common"],
      "hooks": "kiro-ts",
      "testCommand": "npm test"
    }
  }
}
